tools/cli) - To view CLI documentation for Hydrogen (custom storefront) development\n\n## Contribute 👩🏽‍💻\n\nIf you'd like to contribute to the project, check out the [contributors docs](/docs) and the [steps to get started](/docs/cli/get-started.md).\n\n<p>&nbsp;</p>\n\n## References\n\n- [oclif](https://oclif.io/)\n","engines":{"node":">=14.17.0"},"private":false,"scripts":{"lint":"nx lint","test":"nx run theme:test","build":"nx build","clean":"nx clean","lint:fix":"nx lint:fix","test:watch":"nx test:watch","type-check":"nx type-check"},"_npmUser":{"name":"shopify-dep","email":"npmjs+shopify-dep@shopify.com"},"_resolved":"","_integrity":"","deprecated":"This package is deprecated. As of Shopify CLI version 3.59.0, it is bundled with @shopify/cli. Please use that package instead.","repository":{"url":"https://github.com/Shopify/cli/edit/main/packages/theme","type":"git"},"_npmVersion":"6.14.18","description":"Utilities for building and publishing themes","directories":{},"_nodeVersion":"16.13.2","dependencies":{"@oclif/core":"1.21.0","@shopify/cli-kit":"0.0.0-nightly-20230206021118"},"eslintConfig":{"extends":["../../.eslintrc.cjs"]},"engine-strict":true,"publishConfig":{"access":"public","@shopify:registry":"https://registry.npmjs.org"},"_hasShrinkwrap":false,"readmeFilename":"README.md","devDependencies":{"vite":"^2.9.13","vitest":"^0.26.3","@types/node":"14.18.36","node-stream-zip":"^1.15.0"},"_npmOperationalInternal":{"tmp":"tmp/theme_0.0.0-nightly-20230206021118_1675649555114_0.3615720489190233","host":"s3://npm-registry-packages"}},"3.40.0":{"name":"@shopify/theme","version":"3.40.0","license":"MIT","_id":"@shopify/theme@3.40.0","maintainers":[{"name":"crisfmb","email":"cristina.borges@shopify.com"},{"name":"pmoloney89","email":"patrick.moloney@shopify.com"},{"name":"netlohan","email":"annette.lohan@shopify.com"},{"name":"st999999","email":"samantha.turri@shopify.com"},{"name":"justin-irl","email":"justin.preisler@shopify.com"},{"name":"megswim","email":"meg.