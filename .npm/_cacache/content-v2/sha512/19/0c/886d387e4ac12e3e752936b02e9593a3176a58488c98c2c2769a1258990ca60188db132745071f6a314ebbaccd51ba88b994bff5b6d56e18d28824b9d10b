lopment\n- [CLI Documentation - Hydrogen](https://shopify.dev/custom-storefronts/tools/cli) - To view CLI documentation for Hydrogen (custom storefront) development\n\n## Contribute 👩🏽‍💻\n\nIf you'd like to contribute to the project, check out the [contributors docs](/docs) and the [steps to get started](/docs/cli/get-started.md).\n\n<p>&nbsp;</p>\n\n## References\n\n- [oclif](https://oclif.io/)\n","engines":{"node":">=18.12.0"},"private":false,"scripts":{"lint":"nx lint","test":"nx run theme:test","build":"nx build","clean":"nx clean","lint:fix":"nx lint:fix","test:watch":"nx test:watch","type-check":"nx type-check"},"_npmUser":{"name":"shopify-dep","email":"npmjs+shopify-dep@shopify.com"},"_resolved":"","_integrity":"","deprecated":"This package is deprecated. As of Shopify CLI version 3.59.0, it is bundled with @shopify/cli. Please use that package instead.","repository":{"url":"https://github.com/Shopify/cli/edit/main/packages/theme","type":"git"},"_npmVersion":"6.14.18","description":"Utilities for building and publishing themes","directories":{},"_nodeVersion":"16.14.2","dependencies":{"yaml":"2.3.2","@oclif/core":"3.15.1","@shopify/cli-kit":"0.0.0-nightly-20240130144401","@shopify/theme-check-node":"2.0.0","@shopify/theme-language-server-node":"1.7.2"},"eslintConfig":{"extends":["../../.eslintrc.cjs"]},"engine-strict":true,"publishConfig":{"access":"public","@shopify:registry":"https://registry.npmjs.org"},"_hasShrinkwrap":false,"readmeFilename":"README.md","devDependencies":{"vite":"^4.4.9","vitest":"^0.34.3","@types/node":"18.19.3","node-stream-zip":"^1.15.0"},"_npmOperationalInternal":{"tmp":"tmp/theme_0.0.0-nightly-20240130144401_1706625933583_0.3561794756326446","host":"s3://npm-registry-packages"}},"3.55.0":{"name":"@shopify/theme","version":"3.55.0","license":"MIT","_id":"@shopify/theme@3.55.0","maintainers":[{"name":"jaimie.rockburn","email":"jaimie.rockburn@shopify.com"},{"name":"blittle","email":"bret.little@gmail.com"},{"name":"shopify-admin","emai