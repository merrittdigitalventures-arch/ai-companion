from flask import Flask, request, redirect, url_for, render_template_string
app = Flask(__name__)
STATE = {"niche_mode": None, "niche": None, "product": None}
BASE_HTML = """
<!doctype html>
<html>
<head>
    <title>OperatorOS Beta</title>
    <style>
        body { font-family: Arial, sans-serif; background:#111; color:#eee; padding:40px; }
        h1 { color:#6cf; }
        button { padding:10px 16px; margin:6px; font-size:16px; }
        input { padding:8px; font-size:16px; }
        .box { background:#1b1b1b; padding:20px; border-radius:8px; max-width:600px; }
    </style>
</head>
<body>
<div class="box">
    {{ content }}
</div>
</body>
</html>
"""
@app.route("/")
def index():
    content = '<h1>OperatorOS (Beta)</h1><p>Automated digital product engine.</p><a href="/niche"><button>Start</button></a>'
    return render_template_string(BASE_HTML, content=content)
@app.route("/niche", methods=["GET", "POST"])
def niche():
    if request.method == "POST":
        STATE["niche_mode"] = request.form["mode"]
        return redirect(url_for("niche_manual" if STATE["niche_mode"] == "manual" else "niche_auto"))
    content = """
    <h1>Choose Niche Mode</h1>
    <form method="post">
        <button name="mode" value="auto">Auto-Discover Profitable Niche</button><br><br>
        <button name="mode" value="manual">I Have a Niche in Mind</button>
    </form>
    """
    return render_template_string(BASE_HTML, content=content)
@app.route("/niche/manual", methods=["GET", "POST"])
def niche_manual():
    if request.method == "POST":
        STATE["niche"] = request.form["niche"]
        return redirect("/product")
    content = '<h1>Manual Niche Entry</h1><form method="post"><input name="niche" placeholder="e.g. Fitness for Men 40+" required><br><br><button>Continue</button></form>'
    return render_template_string(BASE_HTML, content=content)
@app.route("/niche/auto")
def niche_auto():
    STATE["niche"] = "Auto-Discovered Niche (Stub)"
    return redirect("/product")
@app.route("/product", methods=["GET", "POST"])
def product():
    if request.method == "POST":
        STATE["product"] = request.form["product"]
        return redirect("/bundle")
    content = f'<h1>Choose Product Type</h1><p><b>Niche:</b> {STATE["niche"]}</p><form method="post"><button name="product" value="ebook">E-Book</button><button name="product" value="bundle">Bundle</button><button name="product" value="course">Mini-Course</button></form>'
    return render_template_string(BASE_HTML, content=content)
@app.route("/bundle")
def bundle():
    content = f'<h1>Bundle Generator</h1><p><b>Niche:</b> {STATE["niche"]}</p><p><b>Product:</b> {STATE["product"]}</p><p>(Generation logic coming next)</p><a href="/publish"><button>Continue</button></a>'
    return render_template_string(BASE_HTML, content=content)
@app.route("/publish")
def publish():
    content = '<h1>Publish</h1><p>Gumroad / LemonSqueezy / Stripe coming next.</p><a href="/promote"><button>Continue</button></a>'
    return render_template_string(BASE_HTML, content=content)
@app.route("/promote")
def promote():
    content = '<h1>Promotion Engine</h1><p>Social + SEO automation coming next.</p><h3>Flow complete.</h3>'
    return render_template_string(BASE_HTML, content=content)
app.run(debug=True)
